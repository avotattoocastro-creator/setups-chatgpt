<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AvoPerformanceSetupAI.Views.InicioPage"
    x:Name="InicioPageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:AvoPerformanceSetupAI.Models"
    Background="{StaticResource CarbonBackgroundBrush}"
    RequestedTheme="Dark">

    <Grid Padding="24">
        <StackPanel Spacing="12">
            <TextBlock Text="Inicio"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#FFE0F0F0"/>
            <TextBlock Text="Bienvenido a AvoPerformanceSetupAI. Usa las pestañas para configurar, gestionar sesiones y telemetría."
                       Foreground="#FF8AABAB"
                       TextWrapping="Wrap"/>

            <!-- Selector rápido de coche, pista, source y modo -->
            <Border Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Configuración rápida"
                               FontWeight="SemiBold" Foreground="#FFE0F0F0"/>
                    <Grid ColumnSpacing="12" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Column="0" Grid.Row="0" Text="Car ID" Foreground="#FF8AABAB" FontSize="11"/>
                        <TextBlock Grid.Column="1" Grid.Row="0" Text="Track ID" Foreground="#FF8AABAB" FontSize="11"/>
                        <TextBlock Grid.Column="2" Grid.Row="0" Text="Archivo de setup" Foreground="#FF8AABAB" FontSize="11"/>
                        <TextBlock Grid.Column="3" Grid.Row="0" Text="Source" Foreground="#FF8AABAB" FontSize="11"/>
                        <TextBlock Grid.Column="4" Grid.Row="0" Text="Mode" Foreground="#FF8AABAB" FontSize="11"/>
                        <TextBlock Grid.Column="5" Grid.Row="0" Text="Start" Foreground="#FF8AABAB" FontSize="11"/>
                        <TextBlock Grid.Column="6" Grid.Row="0" Text="Connect" Foreground="#FF8AABAB" FontSize="11"/>
                        <TextBlock Grid.Column="7" Grid.Row="0" Text="Apply" Foreground="#FF8AABAB" FontSize="11"/>
                        <TextBlock Grid.Column="8" Grid.Row="0" Text="Run AI" Foreground="#FF8AABAB" FontSize="11"/>

                        <ComboBox Grid.Column="0" Grid.Row="1"
                                  ItemsSource="{Binding Cars}"
                                  SelectedItem="{Binding CarId, Mode=TwoWay}"
                                  PlaceholderText="— Seleccionar coche —"
                                  Background="#FF0F2020" Foreground="#FFE0F0F0"
                                  BorderBrush="#FF2E4040"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Top"/>
                        <ComboBox Grid.Column="1" Grid.Row="1"
                                  ItemsSource="{Binding Tracks}"
                                  SelectedItem="{Binding TrackId, Mode=TwoWay}"
                                  PlaceholderText="— Seleccionar circuito —"
                                  Background="#FF0F2020" Foreground="#FFE0F0F0"
                                  BorderBrush="#FF2E4040"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Top"/>
                        <ComboBox Grid.Column="2" Grid.Row="1"
                                ItemsSource="{Binding SetupFiles}"
                                SelectedItem="{Binding SelectedSetupFile, Mode=TwoWay}"
                                PlaceholderText="Selecciona el setup (.ini)"
                                Background="#FF0F2020"
                                Foreground="#FFE0F0F0"
                                BorderBrush="#FF2E4040"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top"/>  
                        <ComboBox Grid.Column="3" Grid.Row="1"
                                  ItemsSource="{Binding SetupSources}"
                                  SelectedItem="{Binding SetupSource, Mode=TwoWay}"
                                  PlaceholderText="Source"
                                  HorizontalAlignment="Left"
                                  Width="Auto"
                                  MinWidth="90"
                                  VerticalAlignment="Top"/>
                        <ComboBox Grid.Column="4" Grid.Row="1"
                                  ItemsSource="{Binding Modes}"
                                  SelectedItem="{Binding Mode, Mode=TwoWay}"
                                  PlaceholderText="Mode"
                                  HorizontalAlignment="Left"
                                  Width="Auto"
                                  MinWidth="80"
                                  VerticalAlignment="Top"/>
                        <Button Grid.Column="5" Grid.Row="1" Content="▶ Start" Style="{StaticResource AccentActionButton}"
                                Command="{Binding StartCommand}"
                                VerticalAlignment="Top"/>
                        <Button Grid.Column="6" Grid.Row="1" Content="⚡ Connect" Style="{StaticResource SecondaryActionButton}"
                                Command="{Binding ConnectCommand}"
                                VerticalAlignment="Top"/>
                        <Button Grid.Column="7" Grid.Row="1" Content="✔ Apply" Style="{StaticResource AccentActionButton}"
                                Command="{Binding ApplyProposalCommand}"
                                VerticalAlignment="Top"/>
                        <Button Grid.Column="8" Grid.Row="1" Content="Run AI" Style="{StaticResource RunButtonStyle}"
                                Height="36"
                                Command="{Binding RunAiCommand}"
                                VerticalAlignment="Top"/>
									
                    </Grid>


                </StackPanel>
            </Border>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Columna 1: Propuestas IA -->
                <Border Grid.Column="0" Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20" Height="420">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  FontSize="{Binding DataContext.ContentFontSize, ElementName=InicioPageRoot}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Propuestas IA" FontWeight="SemiBold" Foreground="#FFE0F0F0"/>
                            <TextBlock Text="Cambios generados al ejecutar RUN"
                                       Foreground="#FF507070"/>
                            <ItemsControl ItemsSource="{Binding SetupEntryDiffs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:SetupEntryProposal">
                                        <Grid ColumnSpacing="8" Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Spacing="0">
                                                <TextBlock Text="{x:Bind Section}" Foreground="#FF507070"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{x:Bind Key}" Foreground="#FFB0D0D0"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{x:Bind Current}" Foreground="#FF8AABAB"/>
                                            <TextBlock Grid.Column="2" Text="→" Foreground="#FF8AABAB"
                                                       Visibility="{x:Bind ChangeVisibility}"/>
                                            <TextBlock Grid.Column="3" Text="{x:Bind Proposed}" Foreground="#FF00D4B4" FontWeight="SemiBold"
                                                       Visibility="{x:Bind ChangeVisibility}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Columna 2: Registro de sesiones -->
                <Border Grid.Column="1" Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16" Height="420">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Registro de sesiones" FontWeight="SemiBold" Foreground="#FFE0F0F0"/>
                        <TextBlock Text="Mejores vueltas por coche/pista/setup" Foreground="#FF507070" FontSize="11"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding SessionLogs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="8" Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="110"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding CarId}" Foreground="#FFB0D0D0" FontFamily="Consolas"/>
                                            <TextBlock Grid.Column="1" Text="{Binding TrackId}" Foreground="#FFB0D0D0" FontFamily="Consolas"/>
                                            <TextBlock Grid.Column="2" Text="{Binding SetupFile}" Foreground="#FF8AABAB" TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="Best" Foreground="#FF507070" FontSize="11"/>
                                                <TextBlock Text="{Binding BestLapDisplay}" Foreground="#FF00D4B4" FontWeight="SemiBold"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                                <TextBlock Text="Laps" Foreground="#FF507070" FontSize="11"/>
                                                <TextBlock Text="{Binding CompletedLaps}" Foreground="#FFB0D0D0"/>
                                                <TextBlock Text="·" Foreground="#FF507070"/>
                                                <TextBlock Text="{Binding SessionDateLocal}" Foreground="#FF8AABAB" FontSize="11"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- Columna 3: Telemetría rápida + fuente -->
                <StackPanel Grid.Column="2" Spacing="10" Height="420">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                        <TextBlock Text="Tamaño de fuente" VerticalAlignment="Center" Foreground="#FF8AABAB"/>
                        <Slider Width="140" Minimum="10" Maximum="26" StepFrequency="1"
                                Value="{Binding ContentFontSize, Mode=TwoWay}"/>
                        <Button Content="−" Width="32" Style="{StaticResource SecondaryActionButton}"
                                Command="{Binding DecreaseContentFontCommand}"/>
                        <Button Content="+" Width="32" Style="{StaticResource AccentActionButton}"
                                Command="{Binding IncreaseContentFontCommand}"/>
                        <TextBlock Text="{Binding ContentFontSizeLabel}"
                                   VerticalAlignment="Center" Foreground="#FF8AABAB"/>
                    </StackPanel>

                    <Border Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16" VerticalAlignment="Stretch">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Telemetría rápida (Acelerador / Freno)" FontWeight="SemiBold" Foreground="#FFE0F0F0"/>
                            <TextBlock Text="Sparkline en tiempo real (últimos segundos)" Foreground="#FF507070" FontSize="11"/>
                            <Canvas Width="440" Height="90" Background="#FF0E1818">
                                <Polyline Points="{Binding ThrottlePoints, Mode=OneWay}"
                                          Stroke="#FF00D4B4" StrokeThickness="2" StrokeLineJoin="Round"/>
                                <Polyline Points="{Binding BrakePoints, Mode=OneWay}"
                                          Stroke="#FFFF7A70" StrokeThickness="2" StrokeLineJoin="Round"/>
                            </Canvas>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Rectangle Width="14" Height="8" Fill="#FF00D4B4" RadiusX="2" RadiusY="2"/>
                                    <TextBlock Text="Acelerador" Foreground="#FF8AABAB" FontSize="11"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Rectangle Width="14" Height="8" Fill="#FFFF7A70" RadiusX="2" RadiusY="2"/>
                                    <TextBlock Text="Freno" Foreground="#FF8AABAB" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</Page>
