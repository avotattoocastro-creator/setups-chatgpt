<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AvoPerformanceSetupAI.Views.ConfiguracionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource CarbonBackgroundBrush}"
    RequestedTheme="Dark">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="600">
            <TextBlock Text="Configuración" FontSize="24" FontWeight="SemiBold" Foreground="#FFE0F0F0"/>
            <TextBlock Text="Ajustes y preferencias de la aplicación." Foreground="#FF8AABAB"/>

            <!-- Setup Folder -->
            <Border Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Carpeta de Setups" FontWeight="SemiBold" Foreground="#FFE0F0F0"/>
                    <TextBlock Text="Selecciona la carpeta raíz que contiene las subcarpetas de coches y circuitos."
                               Foreground="#FF8AABAB" FontSize="12" TextWrapping="Wrap"/>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 x:Name="FolderPathBox"
                                 IsReadOnly="True"
                                 PlaceholderText="Ninguna carpeta seleccionada..."
                                 Background="#FF0F2020"
                                 Foreground="#FFE0F0F0"
                                 BorderBrush="#FF2E4040"/>
                        <Button Grid.Column="1"
                                Content="📁 Seleccionar"
                                Click="BrowseFolder_Click"
                                Background="#FF00B4B4"
                                Foreground="White"
                                CornerRadius="6"
                                Padding="12,8"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Output (Destination) Folder -->
            <Border Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Carpeta de Destino (Apply)" FontWeight="SemiBold" Foreground="#FFE0F0F0"/>
                    <TextBlock Text="Carpeta donde se copian los archivos cuando pulsas Apply (p. ej. la carpeta de setups del simulador)."
                               Foreground="#FF8AABAB" FontSize="12" TextWrapping="Wrap"/>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 x:Name="OutputFolderPathBox"
                                 IsReadOnly="True"
                                 PlaceholderText="Ninguna carpeta de destino seleccionada..."
                                 Background="#FF0F2020"
                                 Foreground="#FFE0F0F0"
                                 BorderBrush="#FF2E4040"/>
                        <Button Grid.Column="1"
                                Content="📁 Seleccionar"
                                Click="BrowseOutputFolder_Click"
                                Background="#FF00B4B4"
                                Foreground="White"
                                CornerRadius="6"
                                Padding="12,8"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Language Selector -->
            <Border Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Language / Idioma" FontWeight="SemiBold" Foreground="#FFE0F0F0"/>
                    <ComboBox Width="200" SelectedIndex="0">
                        <ComboBoxItem Content="Español (ES)" />
                        <ComboBoxItem Content="English (EN)" />
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- Theme -->
            <Border Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Theme / Tema" FontWeight="SemiBold" Foreground="#FFE0F0F0"/>
                    <ToggleSwitch Header="Dark Mode" IsOn="True" />
                </StackPanel>
            </Border>

            <!-- UI Scale -->
            <Border Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Escala de Interfaz (UI Scale)" FontWeight="SemiBold" Foreground="#FFE0F0F0"/>
                    <TextBlock Text="Ajusta el tamaño de fuente global de la interfaz. Rango: 1.0× – 1.6×."
                               Foreground="#FF8AABAB" FontSize="12" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock Text="1.0×" Foreground="#FF8AABAB" VerticalAlignment="Center"/>
                        <Slider x:Name="UiScaleSlider"
                                Minimum="1.0" Maximum="1.6" StepFrequency="0.05"
                                Width="260"
                                ValueChanged="UiScaleSlider_ValueChanged"/>
                        <TextBlock Text="1.6×" Foreground="#FF8AABAB" VerticalAlignment="Center"/>
                        <TextBlock x:Name="UiScaleValueText"
                                   Foreground="#FFE0F0F0" FontWeight="SemiBold"
                                   VerticalAlignment="Center" MinWidth="42"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Branding / Marca de fondo -->
            <Border Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Marca de fondo (Branding)" FontWeight="SemiBold" Foreground="#FFE0F0F0"/>
                    <TextBlock Text="Muestra el logotipo AVO Performance como marca de agua sutil en el fondo de la aplicación."
                               Foreground="#FF8AABAB" FontSize="12" TextWrapping="Wrap"/>
                    <ToggleSwitch x:Name="WatermarkEnabledToggle"
                                  Header="Mostrar marca de fondo"
                                  Toggled="WatermarkToggle_Toggled"/>
                    <ToggleSwitch x:Name="SplashScreenToggle"
                                  Header="Mostrar pantalla de inicio"
                                  Toggled="SplashScreenToggle_Toggled"/>
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock Text="Intensidad:" Foreground="#FF8AABAB" VerticalAlignment="Center" MinWidth="80"/>
                        <Slider x:Name="WatermarkOpacitySlider"
                                Minimum="0.02" Maximum="0.12" StepFrequency="0.01"
                                Width="200"
                                ValueChanged="WatermarkOpacity_ValueChanged"/>
                        <TextBlock x:Name="WatermarkOpacityValueText"
                                   Foreground="#FFE0F0F0" FontWeight="SemiBold"
                                   VerticalAlignment="Center" MinWidth="36"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Race View -->
            <Border Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Modo Carrera (Race View)" FontWeight="SemiBold" Foreground="#FFE0F0F0"/>
                    <TextBlock Text="Muestra una vista simplificada con las métricas clave en tamaño grande, optimizada para leer mientras conduces a 1–1.5 metros de la pantalla."
                               Foreground="#FF8AABAB" FontSize="12" TextWrapping="Wrap"/>
                    <ToggleSwitch x:Name="RaceViewToggle"
                                  Header="Activar Modo Carrera"
                                  Toggled="RaceViewToggle_Toggled"/>
                </StackPanel>
            </Border>

            <!-- Remote Agent Connection -->
            <Border Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Conexión Agent Remoto" FontWeight="SemiBold" Foreground="#FFE0F0F0"/>
                    <TextBlock Text="En modo Remote, las carpetas de setup se leen y guardan en el PC simulador a través del Agent."
                               Foreground="#FF8AABAB" FontSize="12" TextWrapping="Wrap"/>

                    <!-- Mode toggle -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ToggleSwitch x:Name="RemoteModeToggle"
                                      Header="Modo Remote (Agent)"
                                      Toggled="RemoteModeToggle_Toggled"
                                      MinWidth="0"/>
                    </StackPanel>

                    <!-- Token warning -->
                    <Border x:Name="TokenWarningBorder"
                            Background="#33FF6000" BorderBrush="#FFFF6000"
                            BorderThickness="1" CornerRadius="4" Padding="10,6"
                            Visibility="Collapsed">
                        <TextBlock Text="⚠ Token vacío — configura el token antes de usar el modo Remote."
                                   Foreground="#FFFFA040" FontSize="12" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Host + Port -->
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Host (IP o nombre)" Foreground="#FF8AABAB" FontSize="11"/>
                            <TextBox x:Name="RemoteHostBox"
                                     PlaceholderText="localhost"
                                     Background="#FF0F2020" Foreground="#FFE0F0F0"
                                     BorderBrush="#FF2E4040"
                                     TextChanged="RemoteHostBox_TextChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="Puerto" Foreground="#FF8AABAB" FontSize="11"/>
                            <NumberBox x:Name="RemotePortBox"
                                       Minimum="1" Maximum="65535"
                                       SpinButtonPlacementMode="Compact"
                                       Background="#FF0F2020" Foreground="#FFE0F0F0"
                                       BorderBrush="#FF2E4040"
                                       ValueChanged="RemotePortBox_ValueChanged"/>
                            <TextBlock Text="HTTP/WS (defecto 8181). Discovery UDP: 8182."
                                       Foreground="#FF607070" FontSize="10" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>

                    <!-- Computed Agent Base URL (read-only) -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Agent Base URL (calculado)" Foreground="#FF8AABAB" FontSize="11"/>
                        <TextBox x:Name="AgentBaseUrlDisplayBox"
                                 IsReadOnly="True"
                                 Background="#FF0A1818" Foreground="#FF8AABAB"
                                 BorderBrush="#FF2E4040" FontFamily="Consolas" FontSize="12"/>
                    </StackPanel>

                    <!-- State check URL (read-only) -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Estado check URL (calculado)" Foreground="#FF8AABAB" FontSize="11"/>
                        <TextBox x:Name="AgentStateUrlDisplayBox"
                                 IsReadOnly="True"
                                 Background="#FF0A1818" Foreground="#FF8AABAB"
                                 BorderBrush="#FF2E4040" FontFamily="Consolas" FontSize="12"/>
                    </StackPanel>

                    <!-- Token -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Token de autenticación (X-API-TOKEN)" Foreground="#FF8AABAB" FontSize="11"/>
                        <PasswordBox x:Name="RemoteTokenBox"
                                     PlaceholderText="Introduce el token..."
                                     Background="#FF0F2020" Foreground="#FFE0F0F0"
                                     BorderBrush="#FF2E4040"
                                     PasswordChanged="RemoteTokenBox_PasswordChanged"/>
                    </StackPanel>

                    <!-- Test Agent button -->
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Button Content="🔌 Probar conexión"
                                Click="TestAgent_Click"
                                Background="#FF1A2020" Foreground="#FF00B4B4"
                                BorderBrush="#FF2E5050" BorderThickness="1"
                                CornerRadius="6" Padding="12,6"/>
                    </StackPanel>

                    <!-- Test result (multi-line) -->
                    <TextBlock x:Name="AgentTestResultText"
                               FontFamily="Consolas" FontSize="12"
                               Foreground="#FF8AABAB"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
