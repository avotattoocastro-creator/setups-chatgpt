<Page
    x:Class="AvoPerformanceSetupAI.Views.CompareSetupsTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:AvoPerformanceSetupAI.ViewModels"
    xmlns:models="using:AvoPerformanceSetupAI.Models"
    Background="#0B0B0B">

    <Page.DataContext>
        <vm:CompareSetupsViewModel />
    </Page.DataContext>

    <Grid Background="#0B0B0B" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Grid Grid.Row="0" Background="#151515" Padding="16,12" CornerRadius="10" BorderBrush="#2A2A2A" BorderThickness="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="COMPARE SETUPS" Foreground="#FFFFFF" FontWeight="SemiBold" FontSize="16" />
                <TextBlock Text="Baseline vs Current vs Iteración" Foreground="#9A9A9A" FontSize="12" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Content="Swap target" Command="{Binding SwapCompareTargetCommand}" Padding="10,6" />
                <Button Content="Aplicar iteración" Command="{Binding ApplySelectedAsCurrentCommand}" Padding="10,6" />
                <Button Content="Nueva iter delta" Command="{Binding CreateIterationFromDeltaCommand}" Padding="10,6" />
                <Button Content="Exportar reporte" Command="{Binding ExportReportCommand}" Padding="10,6" />
            </StackPanel>
        </Grid>

        <!-- Main content -->
        <Grid Grid.Row="1" RowSpacing="12" Background="#0B0B0B">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="260" />
            </Grid.RowDefinitions>

            <!-- Cards -->
            <Grid Grid.Row="0" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Baseline -->
                <Border Grid.Column="0" Background="#151515" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="10" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="BASELINE" Foreground="#FFFFFF" FontWeight="SemiBold" />
                        <TextBlock Foreground="#9A9A9A"><Run Text="ID: " /><Run Text="{Binding Baseline.Id}" /></TextBlock>
                        <TextBlock Foreground="#9A9A9A"><Run Text="Car: " /><Run Text="{Binding Baseline.Car}" /></TextBlock>
                        <TextBlock Foreground="#9A9A9A"><Run Text="Track: " /><Run Text="{Binding Baseline.Track}" /></TextBlock>
                        <ItemsControl ItemsSource="{Binding Baseline.Sections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Key}" Foreground="#9A9A9A" />
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="#FFFFFF" FontFamily="Consolas" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Current -->
                <Border Grid.Column="1" Background="#151515" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="10" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="CURRENT" Foreground="#FFFFFF" FontWeight="SemiBold" />
                        <TextBlock Foreground="#9A9A9A"><Run Text="ID: " /><Run Text="{Binding Current.Id}" /></TextBlock>
                        <TextBlock Foreground="#9A9A9A"><Run Text="Car: " /><Run Text="{Binding Current.Car}" /></TextBlock>
                        <TextBlock Foreground="#9A9A9A"><Run Text="Track: " /><Run Text="{Binding Current.Track}" /></TextBlock>
                        <ItemsControl ItemsSource="{Binding Current.Sections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Key}" Foreground="#9A9A9A" />
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="#FFFFFF" FontFamily="Consolas" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Iteration -->
                <Border Grid.Column="2" Background="#151515" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="10" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="SELECTED ITERATION" Foreground="#FFFFFF" FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding Iterations}" SelectedItem="{Binding SelectedIteration, Mode=TwoWay}" Background="#0B0B0B" Foreground="#FFFFFF" />
                        <TextBlock Foreground="#9A9A9A"><Run Text="ID: " /><Run Text="{Binding SelectedIteration.Id}" /></TextBlock>
                        <TextBlock Foreground="#9A9A9A"><Run Text="Car: " /><Run Text="{Binding SelectedIteration.Car}" /></TextBlock>
                        <TextBlock Foreground="#9A9A9A"><Run Text="Track: " /><Run Text="{Binding SelectedIteration.Track}" /></TextBlock>
                        <ItemsControl ItemsSource="{Binding SelectedIteration.Sections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Key}" Foreground="#9A9A9A" />
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="#FFFFFF" FontFamily="Consolas" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Impact estimator -->
            <Border Grid.Row="1" Background="#151515" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="10" Padding="12">
                <StackPanel Spacing="10">
                    <TextBlock Text="IMPACT ESTIMATOR" Foreground="#FFFFFF" FontWeight="SemiBold" />
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Predicted LapTime" Foreground="#9A9A9A" />
                        <ProgressBar Grid.Row="0" Grid.Column="1" Height="8" Minimum="80" Maximum="120" Value="{Binding Impact.PredictedLapTime}" Foreground="#00D1FF" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding Impact.PredictedLapTime}" Foreground="#FFFFFF" FontFamily="Consolas" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Balance Score" Foreground="#9A9A9A" />
                        <ProgressBar Grid.Row="1" Grid.Column="1" Height="8" Minimum="0" Maximum="100" Value="{Binding Impact.BalanceScore}" Foreground="#E10600" />
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding Impact.BalanceScore}" Foreground="#FFFFFF" FontFamily="Consolas" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Tyre Heat Risk" Foreground="#9A9A9A" />
                        <ProgressBar Grid.Row="2" Grid.Column="1" Height="8" Minimum="0" Maximum="100" Value="{Binding Impact.TyreHeatRisk}" Foreground="#E10600" />
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding Impact.TyreHeatRisk}" Foreground="#FFFFFF" FontFamily="Consolas" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Stability Risk" Foreground="#9A9A9A" />
                        <ProgressBar Grid.Row="3" Grid.Column="1" Height="8" Minimum="0" Maximum="100" Value="{Binding Impact.StabilityRisk}" Foreground="#E10600" />
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding Impact.StabilityRisk}" Foreground="#FFFFFF" FontFamily="Consolas" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Aero Efficiency" Foreground="#9A9A9A" />
                        <ProgressBar Grid.Row="4" Grid.Column="1" Height="8" Minimum="0" Maximum="100" Value="{Binding Impact.AeroEfficiency}" Foreground="#00D1FF" />
                        <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding Impact.AeroEfficiency}" Foreground="#FFFFFF" FontFamily="Consolas" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Bottom status bar -->
        <Border Grid.Row="2" Background="#151515" BorderBrush="#2A2A2A" BorderThickness="1" Padding="12,6" CornerRadius="10">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Reports: " Foreground="#9A9A9A" />
                <TextBlock Text="Documents\\AvoPerformanceSetupAI\\Reports" Foreground="#FFFFFF" FontFamily="Consolas" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
