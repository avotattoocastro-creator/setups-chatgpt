<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AvoPerformanceSetupAI.Views.TelemetryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:AvoPerformanceSetupAI.Models"
    xmlns:converters="using:AvoPerformanceSetupAI.Converters"
    xmlns:controls="using:AvoPerformanceSetupAI.Controls"
    xmlns:local="using:AvoPerformanceSetupAI.Reference"
    xmlns:telemetry="using:AvoPerformanceSetupAI.Telemetry"
    xmlns:ml="using:AvoPerformanceSetupAI.ML"
    xmlns:agent="using:AvoPerformanceSetupAI.Services.Agent"
    Background="{StaticResource CarbonBackgroundBrush}"
    RequestedTheme="Dark">

    <Page.Resources>

        <!-- ═══ Channel card helpers:
             All font sizes via MultiplyConverter (min = FontBaseSmall = 14).
             Values in white #FFFFFF.  Deltas in green #00FF88.
        ═══ -->

        <!-- Real telemetry channel card -->
        <DataTemplate x:Key="RealChannelCard" x:DataType="models:TelemetryChannel">
            <Border Background="#FF1E3030"
                    BorderBrush="#FF2E4848" BorderThickness="1"
                    CornerRadius="{Binding Source={StaticResource CardCornerRadiusBase}, Converter={StaticResource ScaleCr}}"
                    MinHeight="{Binding Source={StaticResource CardMinHeightBase}, Converter={StaticResource Mul}}"
                    Padding="{Binding Source={StaticResource CardPaddingBase}, Converter={StaticResource ScaleTh}}"
                    Margin="{Binding Source={StaticResource CardMarginBase}, Converter={StaticResource ScaleTh}}">
                <StackPanel Spacing="4">
                    <TextBlock Text="{x:Bind Name}"
                               FontFamily="Consolas"
                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                               FontWeight="SemiBold" Opacity="0.75"
                               Foreground="#FF8AABAB"/>
                    <StackPanel Orientation="Horizontal" Spacing="3">
                        <TextBlock Text="{x:Bind RealDisplay, Mode=OneWay}"
                                   FontFamily="Consolas"
                                   FontSize="{Binding Source={StaticResource FontBaseBigMetric}, Converter={StaticResource Mul}}"
                                   FontWeight="Bold" Foreground="#FFFFFFFF"/>
                        <TextBlock Text="{x:Bind Unit}"
                                   FontFamily="Consolas"
                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                   Foreground="#FF8AABAB" VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                    </StackPanel>
                    <TextBlock Text="{x:Bind DeltaDisplay, Mode=OneWay}"
                               FontFamily="Consolas"
                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                               Foreground="#FF00FF88"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Ideal telemetry channel card -->
        <DataTemplate x:Key="IdealChannelCard" x:DataType="models:TelemetryChannel">
            <Border Background="#FF142818"
                    BorderBrush="#FF1E4030" BorderThickness="1"
                    CornerRadius="{Binding Source={StaticResource CardCornerRadiusBase}, Converter={StaticResource ScaleCr}}"
                    MinHeight="{Binding Source={StaticResource CardMinHeightBase}, Converter={StaticResource Mul}}"
                    Padding="{Binding Source={StaticResource CardPaddingBase}, Converter={StaticResource ScaleTh}}"
                    Margin="{Binding Source={StaticResource CardMarginBase}, Converter={StaticResource ScaleTh}}">
                <StackPanel Spacing="4">
                    <TextBlock Text="{x:Bind Name}"
                               FontFamily="Consolas"
                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                               FontWeight="SemiBold" Opacity="0.75"
                               Foreground="#FF8AABAB"/>
                    <StackPanel Orientation="Horizontal" Spacing="3">
                        <TextBlock Text="{x:Bind IdealDisplay, Mode=OneWay}"
                                   FontFamily="Consolas"
                                   FontSize="{Binding Source={StaticResource FontBaseBigMetric}, Converter={StaticResource Mul}}"
                                   FontWeight="Bold" Foreground="#FFFFFFFF"/>
                        <TextBlock Text="{x:Bind Unit}"
                                   FontFamily="Consolas"
                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                   Foreground="#FF8AABAB" VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                    </StackPanel>
                    <TextBlock Text="objetivo"
                               FontFamily="Consolas"
                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                               Opacity="0.5" Foreground="#FF8AABAB"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Converters -->
        <converters:FloatToPercentConverter x:Key="FloatToPercent"/>
        <converters:NotBoolConverter x:Key="NotBoolConverter"/>
        <converters:AcStatusToForegroundConverter x:Key="AcStatusToForeground"/>
        <converters:AcStatusToBackgroundConverter x:Key="AcStatusToBackground"/>
        <converters:AcStatusToBorderConverter x:Key="AcStatusToBorder"/>

        <!-- Analysis log row — min font size = FontBaseSmall (14) -->
        <DataTemplate x:Key="AnalysisEntryRow" x:DataType="models:AnalysisEntry">
            <Grid Padding="0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="96"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{x:Bind Time}"
                           FontFamily="Consolas"
                           FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                           Foreground="#FF607070" VerticalAlignment="Top"/>
                <Border Grid.Column="1"
                        Background="#FF1A3030" CornerRadius="3"
                        Padding="4,2" Margin="4,1,4,0" VerticalAlignment="Top">
                    <TextBlock Text="{x:Bind Tag}"
                               FontFamily="Consolas"
                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                               FontWeight="SemiBold"
                               Foreground="#FF00D4B4" HorizontalAlignment="Center"/>
                </Border>
                <TextBlock Grid.Column="2"
                           Text="{x:Bind Message}"
                           FontFamily="Consolas"
                           FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                           Foreground="#FFB0D0D0"
                           TextWrapping="Wrap" VerticalAlignment="Top"/>
            </Grid>
        </DataTemplate>

    </Page.Resources>

    <Grid x:Name="TelemetryRoot">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="ViewModeStates">
                <!-- NormalMode: race overlay collapsed (default) -->
                <VisualState x:Name="NormalMode"/>
                <!-- RaceViewMode: show large-font overlay, fade in -->
                <VisualState x:Name="RaceViewMode">
                    <VisualState.Storyboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="RaceViewOverlay"
                                Storyboard.TargetProperty="Opacity"
                                From="0" To="1" Duration="0:0:0.200"/>
                        </Storyboard>
                    </VisualState.Storyboard>
                    <VisualState.Setters>
                        <Setter Target="RaceViewOverlay.Visibility" Value="Visible"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="#FF0C1818"
                BorderBrush="#FF2E4040" BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="&#128225;"
                                   FontSize="{Binding Source={StaticResource FontBaseNormal}, Converter={StaticResource Mul}}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Telemetría"
                                   FontSize="{Binding Source={StaticResource FontBaseNormal}, Converter={StaticResource Mul}}"
                                   FontWeight="SemiBold" Foreground="#FFE0F0F0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                               FontFamily="Consolas"
                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                               Foreground="#FF00B4B4" VerticalAlignment="Center"/>
                    <!-- Remote Agent badge: visible only in Remote mode -->
                    <Border Background="#FF0A2030"
                            BorderBrush="#FF2A6080" BorderThickness="1"
                            CornerRadius="4" Padding="6,2" VerticalAlignment="Center"
                            Visibility="{x:Bind IsRemoteModeVisible, Mode=OneWay}">
                        <TextBlock Text="🌐 REMOTE CONNECTED"
                                   FontFamily="Consolas"
                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                   FontWeight="SemiBold" Foreground="#FF40C8FF"/>
                    </Border>
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="Vuelta:" Foreground="#FF8AABAB"
                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"/>
                        <TextBlock Text="{x:Bind ViewModel.LapTimeReal, Mode=OneWay}"
                                   FontFamily="Consolas"
                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                   FontWeight="Bold" Foreground="#FFFFFFFF"/>
                        <TextBlock Text="{x:Bind ViewModel.LapDelta, Mode=OneWay}"
                                   FontFamily="Consolas"
                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                   Foreground="#FF00FF88"/>
                        <TextBlock Text="/ Ideal:" Foreground="#FF8AABAB"
                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"/>
                        <TextBlock Text="{x:Bind ViewModel.LapTimeIdeal, Mode=OneWay}"
                                   FontFamily="Consolas"
                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                   FontWeight="Bold" Foreground="#FFFFFFFF"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="&#128260;"
                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Bind ViewModel.LapPositionText, Mode=OneWay}"
                                   FontFamily="Consolas"
                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                   FontWeight="Bold" Foreground="#FF00FF88" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Background="{x:Bind ViewModel.ConnectionStatusText, Mode=OneWay, Converter={StaticResource AcStatusToBackground}}"
                            BorderBrush="{x:Bind ViewModel.ConnectionStatusText, Mode=OneWay, Converter={StaticResource AcStatusToBorder}}"
                            BorderThickness="1" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.ConnectionStatusText, Mode=OneWay}"
                                   FontFamily="Consolas"
                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                   FontWeight="SemiBold"
                                   Foreground="{x:Bind ViewModel.ConnectionStatusText, Mode=OneWay, Converter={StaticResource AcStatusToForeground}}"/>
                    </Border>
                    <Border Background="#FF0A1414" BorderBrush="#FF2E4040" BorderThickness="1"
                            CornerRadius="5" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <ToggleButton Content="SIMULACI&#211;N"
                                          IsChecked="{x:Bind ViewModel.IsSimulationSelected, Mode=TwoWay}"
                                          IsEnabled="{x:Bind ViewModel.IsSimulating, Mode=OneWay, Converter={StaticResource NotBoolConverter}}"
                                          FontFamily="Consolas"
                                          FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                          FontWeight="SemiBold"
                                          Padding="10,3" CornerRadius="4,0,0,4" MinWidth="0" BorderThickness="0"/>
                            <ToggleButton Content="ASSETTO CORSA REAL"
                                          IsChecked="{x:Bind ViewModel.IsAcSourceSelected, Mode=TwoWay}"
                                          IsEnabled="{x:Bind ViewModel.IsSimulating, Mode=OneWay, Converter={StaticResource NotBoolConverter}}"
                                          FontFamily="Consolas"
                                          FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                          FontWeight="SemiBold"
                                          Padding="10,3" CornerRadius="0,4,4,0" MinWidth="0" BorderThickness="0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <ToggleButton Content="&#127950; Race View"
                                  IsChecked="{x:Bind ViewModel.IsRaceViewActive, Mode=TwoWay}"
                                  FontFamily="Consolas"
                                  FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                  Padding="14,6" CornerRadius="6"
                                  Background="#FF1A2020" Foreground="#FF00B4B4"
                                  BorderBrush="#FF2E5050" BorderThickness="1"/>
                    <Button Content="&#9654; Iniciar"
                            Command="{x:Bind ViewModel.StartSimulationCommand}"
                            Background="#FF00B4B4" Foreground="White"
                            CornerRadius="6" Padding="14,6"
                            FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"/>
                    <Button Content="&#9209; Pausar"
                            Command="{x:Bind ViewModel.StopSimulationCommand}"
                            Background="#FF2A3A3A" Foreground="#FFB0C8C8"
                            CornerRadius="6" Padding="14,6"
                            FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"/>
                    <Button Content="&#128465; Limpiar"
                            Command="{x:Bind ViewModel.ClearAnalysisCommand}"
                            Background="#FF1E2A2A" Foreground="#FF8AABAB"
                            BorderBrush="#FF2E4040" BorderThickness="1"
                            CornerRadius="6" Padding="12,6"
                            FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"/>
                </StackPanel>

                <!-- Reference lap toolbar Row 1 -->
                <Border Grid.Row="1" Grid.ColumnSpan="3"
                        BorderBrush="#FF1A3030" BorderThickness="0,1,0,0"
                        Margin="0,8,0,0" Padding="0,6,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button Content="&#9210; Grabar vuelta ideal"
                                Command="{x:Bind ViewModel.StartRecordingCommand}"
                                Background="#FF1A3030" Foreground="#FF00D4B4"
                                BorderBrush="#FF2E5050" BorderThickness="1"
                                CornerRadius="5" Padding="10,4"
                                FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"/>
                        <Button Content="&#10006; Cancelar grabaci&#243;n"
                                Command="{x:Bind ViewModel.CancelRecordingCommand}"
                                Background="#FF2A1A1A" Foreground="#FFFF6060"
                                BorderBrush="#FF4A2020" BorderThickness="1"
                                CornerRadius="5" Padding="10,4"
                                FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"/>
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                                    Visibility="{x:Bind ViewModel.IsRecording, Mode=OneWay}">
                            <TextBlock Text="REC" FontFamily="Consolas"
                                       FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                       FontWeight="SemiBold" Foreground="#FFFF4040" VerticalAlignment="Center"/>
                            <ProgressBar Value="{x:Bind ViewModel.RecordingProgress, Mode=OneWay}"
                                         Maximum="1" Width="120" Height="8"
                                         Background="#FF1A3030" Foreground="#FFFF4040"/>
                        </StackPanel>
                        <Button Content="&#128194; Importar CSV ideal"
                                Click="OnImportCsvClicked"
                                Background="#FF1A2030" Foreground="#FF80B4E0"
                                BorderBrush="#FF2A3850" BorderThickness="1"
                                CornerRadius="5" Padding="10,4"
                                FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"/>
                        <ComboBox PlaceholderText="Seleccionar Ideal"
                                  ItemsSource="{x:Bind ViewModel.SavedReferences}"
                                  SelectedItem="{x:Bind ViewModel.SelectedReference, Mode=TwoWay}"
                                  MinWidth="220" FontFamily="Consolas"
                                  FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                  Background="#FF0A1414" BorderBrush="#FF2E4040">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="local:ReferenceLapMeta">
                                    <TextBlock Text="{x:Bind DisplayName}" FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind ViewModel.ActiveReferenceName, Mode=OneWay}"
                                       FontFamily="Consolas"
                                       FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                       FontWeight="SemiBold" Foreground="#FF00FF88"/>
                            <TextBlock Text="{x:Bind ViewModel.ReferenceSource, Mode=OneWay}"
                                       FontFamily="Consolas"
                                       FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                       Opacity="0.6" Foreground="#FF8AABAB"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>

        <!-- ── Reconnect suggestion banner ─────────────────────────────── -->
        <InfoBar Grid.Row="1"
                 IsOpen="{x:Bind ViewModel.ShowSwitchToSimulationPrompt, Mode=OneWay}"
                 Severity="Warning"
                 Title="Assetto Corsa no responde"
                 Message="10 intentos de reconexi&#243;n fallaron. &#191;Cambiar a modo Simulaci&#243;n?"
                 IsClosable="False"
                 Margin="8,4">
            <InfoBar.Content>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Seguir intentando"
                            Command="{x:Bind ViewModel.DismissSwitchToSimulationCommand}"
                            Background="#FF2A3A3A" Foreground="#FFB0C8C8"
                            CornerRadius="4" Padding="10,4"
                            FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"/>
                    <Button Content="Cambiar a Simulaci&#243;n"
                            Command="{x:Bind ViewModel.ConfirmSwitchToSimulationCommand}"
                            Background="#FF00B4B4" Foreground="White"
                            CornerRadius="4" Padding="10,4"
                            FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"/>
                </StackPanel>
            </InfoBar.Content>
        </InfoBar>

        <!-- ── Inner Telemetr&#237;a TabView ─────────────────────────────────── -->
        <TabView Grid.Row="2"
                 Background="#FF0C1818"
                 TabWidthMode="SizeToContent"
                 IsAddTabButtonVisible="False">
            <TabView.Resources>
                <SolidColorBrush x:Key="TabViewBackground" Color="#FF0C1818" />
                <Style TargetType="TabViewItem">
                    <Setter Property="FontSize" Value="{StaticResource FontBaseNormal}"/>
                    <Setter Property="Padding" Value="16,8"/>
                </Style>
            </TabView.Resources>

            <!-- ── Dashboard: Real + Ideal (collapsible Expanders) ── -->
            <TabViewItem Header="Dashboard" IsClosable="False">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Padding="8,8" Spacing="8">

                        <!-- Real panel — expanded by default -->
                        <Expander IsExpanded="True"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="&#128202;"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="TELEMETR&#205;A REAL"
                                               FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseNormal}, Converter={StaticResource Mul}}"
                                               FontWeight="SemiBold" Foreground="#FF00B4B4" VerticalAlignment="Center"/>
                                    <TextBlock Text="tiempo real  &#183;  delta verde = Real &#8722; Ideal"
                                               FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                               Opacity="0.6" Foreground="#FF8AABAB" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Expander.Header>
                            <ItemsControl ItemsSource="{x:Bind ViewModel.Channels}"
                                          ItemTemplate="{StaticResource RealChannelCard}"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <!-- Single horizontal line; scrolls if overflow -->
                                        <ItemsStackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </Expander>

                        <!-- Ideal panel — collapsed by default -->
                        <Expander IsExpanded="False"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="&#127919;"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="TELEMETR&#205;A IDEAL"
                                               FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseNormal}, Converter={StaticResource Mul}}"
                                               FontWeight="SemiBold" Foreground="#FF00B4B4" VerticalAlignment="Center"/>
                                    <TextBlock Text="valores objetivo ajustados por posici&#243;n en pista"
                                               FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                               Opacity="0.6" Foreground="#FF8AABAB" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Expander.Header>
                            <ItemsControl ItemsSource="{x:Bind ViewModel.Channels}"
                                          ItemTemplate="{StaticResource IdealChannelCard}"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsStackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </Expander>

                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <!-- ── Live Analysis ────────────────── -->
            <TabViewItem Header="Live Analysis" IsClosable="False">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                <Border Background="#FF0F1A1A"
                        BorderBrush="#FF2E4040" BorderThickness="0,0,0,1"
                        Padding="10,8">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Status card: Speed / Gear / RPM / Phase / Corner -->
                        <Border Grid.Column="0" Background="#FF1E3030"
                                BorderBrush="#FF2E4848" BorderThickness="1"
                                CornerRadius="{Binding Source={StaticResource CardCornerRadiusBase}, Converter={StaticResource ScaleCr}}"
                                Padding="{Binding Source={StaticResource CardPaddingBase}, Converter={StaticResource ScaleTh}}"
                                MinHeight="{Binding Source={StaticResource CardMinHeightBase}, Converter={StaticResource Mul}}">
                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="&#127950;"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="AN&#193;LISIS EN VIVO"
                                               FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                               FontWeight="SemiBold" Foreground="#FF00B4B4" VerticalAlignment="Center"/>
                                </StackPanel>
                                <!-- Speed / Gear / RPM — Big metrics #FFFFFF Bold -->
                                <StackPanel Orientation="Horizontal" Spacing="20">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="VEL" FontFamily="Consolas"
                                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                   FontWeight="SemiBold" Opacity="0.75" Foreground="#FF8AABAB"/>
                                        <StackPanel Orientation="Horizontal" Spacing="2">
                                            <TextBlock Text="{x:Bind ViewModel.Channels[0].RealDisplay, Mode=OneWay}"
                                                       FontFamily="Consolas"
                                                       FontSize="{Binding Source={StaticResource FontBaseBigMetric}, Converter={StaticResource Mul}}"
                                                       FontWeight="Bold" Foreground="#FFFFFFFF"/>
                                            <TextBlock Text="km/h" FontFamily="Consolas"
                                                       FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                       Foreground="#FF8AABAB" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="MARCHA" FontFamily="Consolas"
                                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                   FontWeight="SemiBold" Opacity="0.75" Foreground="#FF8AABAB"/>
                                        <TextBlock Text="{x:Bind ViewModel.Channels[2].RealDisplay, Mode=OneWay}"
                                                   FontFamily="Consolas"
                                                   FontSize="{Binding Source={StaticResource FontBaseBigMetric}, Converter={StaticResource Mul}}"
                                                   FontWeight="Bold" Foreground="#FFFFFFFF"/>
                                    </StackPanel>
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="RPM" FontFamily="Consolas"
                                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                   FontWeight="SemiBold" Opacity="0.75" Foreground="#FF8AABAB"/>
                                        <TextBlock Text="{x:Bind ViewModel.Channels[1].RealDisplay, Mode=OneWay}"
                                                   FontFamily="Consolas"
                                                   FontSize="{Binding Source={StaticResource FontBaseBigMetric}, Converter={StaticResource Mul}}"
                                                   FontWeight="Bold" Foreground="#FFFFFFFF"/>
                                    </StackPanel>
                                </StackPanel>
                                <!-- Phase + Corner — Metric #FFFFFF SemiBold -->
                                <StackPanel Orientation="Horizontal" Spacing="20">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="FASE" FontFamily="Consolas"
                                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                   FontWeight="SemiBold" Opacity="0.75" Foreground="#FF8AABAB"/>
                                        <TextBlock Text="{x:Bind ViewModel.CurrentPhase, Mode=OneWay}"
                                                   FontFamily="Consolas"
                                                   FontSize="{Binding Source={StaticResource FontBaseMetric}, Converter={StaticResource Mul}}"
                                                   FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                                    </StackPanel>
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="&#218;LT. CURVA" FontFamily="Consolas"
                                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                   FontWeight="SemiBold" Opacity="0.75" Foreground="#FF8AABAB"/>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{x:Bind ViewModel.LastCornerDirection, Mode=OneWay}"
                                                       FontFamily="Consolas"
                                                       FontSize="{Binding Source={StaticResource FontBaseMetric}, Converter={StaticResource Mul}}"
                                                       FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                                            <TextBlock Text="{x:Bind ViewModel.LastCornerDurationText, Mode=OneWay}"
                                                       FontFamily="Consolas"
                                                       FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                       Foreground="#FF8AABAB" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Meters card: 5 progress bars -->
                        <Border Grid.Column="1" Background="#FF1E3030"
