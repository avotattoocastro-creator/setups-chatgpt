                                                 Value="{x:Bind ViewModel.LastCornerUndersteerEntry, Mode=OneWay}"
                                                 Background="#FF1A3030" Foreground="#FFFFA040"/>
                                    <TextBlock Grid.Column="2" FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                               Foreground="#FFFFFFFF" HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Text="{x:Bind ViewModel.LastCornerUndersteerEntry, Converter={StaticResource FloatToPercent}, Mode=OneWay}"/>
                                </Grid>
                                <!-- US Mid -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="44"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="US Medio" FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                               Foreground="#FF8AABAB" VerticalAlignment="Center"/>
                                    <ProgressBar Grid.Column="1" Maximum="1" Height="8" Margin="6,0"
                                                 Value="{x:Bind ViewModel.LastCornerUndersteerMid, Mode=OneWay}"
                                                 Background="#FF1A3030" Foreground="#FFFFA040"/>
                                    <TextBlock Grid.Column="2" FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                               Foreground="#FFFFFFFF" HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Text="{x:Bind ViewModel.LastCornerUndersteerMid, Converter={StaticResource FloatToPercent}, Mode=OneWay}"/>
                                </Grid>
                                <!-- US Exit -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="44"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="US Salida" FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                               Foreground="#FF8AABAB" VerticalAlignment="Center"/>
                                    <ProgressBar Grid.Column="1" Maximum="1" Height="8" Margin="6,0"
                                                 Value="{x:Bind ViewModel.LastCornerUndersteerExit, Mode=OneWay}"
                                                 Background="#FF1A3030" Foreground="#FFFFA040"/>
                                    <TextBlock Grid.Column="2" FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                               Foreground="#FFFFFFFF" HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Text="{x:Bind ViewModel.LastCornerUndersteerExit, Converter={StaticResource FloatToPercent}, Mode=OneWay}"/>
                                </Grid>
                                <!-- OS Entry -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="44"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="OS Entrada" FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                               Foreground="#FF8AABAB" VerticalAlignment="Center"/>
                                    <ProgressBar Grid.Column="1" Maximum="1" Height="8" Margin="6,0"
                                                 Value="{x:Bind ViewModel.LastCornerOversteerEntry, Mode=OneWay}"
                                                 Background="#FF1A3030" Foreground="#FFE04040"/>
                                    <TextBlock Grid.Column="2" FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                               Foreground="#FFFFFFFF" HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Text="{x:Bind ViewModel.LastCornerOversteerEntry, Converter={StaticResource FloatToPercent}, Mode=OneWay}"/>
                                </Grid>
                                <!-- OS Exit -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="44"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="OS Salida" FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                               Foreground="#FF8AABAB" VerticalAlignment="Center"/>
                                    <ProgressBar Grid.Column="1" Maximum="1" Height="8" Margin="6,0"
                                                 Value="{x:Bind ViewModel.LastCornerOversteerExit, Mode=OneWay}"
                                                 Background="#FF1A3030" Foreground="#FFE04040"/>
                                    <TextBlock Grid.Column="2" FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                               Foreground="#FFFFFFFF" HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Text="{x:Bind ViewModel.LastCornerOversteerExit, Converter={StaticResource FloatToPercent}, Mode=OneWay}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- VS Ideal delta card — ALL deltas in #00FF88 -->
                        <Border Grid.Column="2" Background="#FF112018"
                                BorderBrush="#FF1E4030" BorderThickness="1"
                                CornerRadius="{Binding Source={StaticResource CardCornerRadiusBase}, Converter={StaticResource ScaleCr}}"
                                Padding="{Binding Source={StaticResource CardPaddingBase}, Converter={StaticResource ScaleTh}}"
                                MinWidth="220" Margin="8,0,0,0">
                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
                                    <TextBlock Text="&#9878;"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="VS IDEAL"
                                               FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                               FontWeight="SemiBold" Foreground="#FF00B4B4" VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind ViewModel.ReferenceSummaryText, Mode=OneWay}"
                                               FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                               Foreground="#FF8AABAB" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <!-- &#916;Speed -->
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="&#916;Vel" FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                               FontWeight="SemiBold" Opacity="0.75"
                                               Foreground="#FF8AABAB" Width="44" VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind ViewModel.LiveDeltaSpeedText, Mode=OneWay}"
                                               FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseMetric}, Converter={StaticResource Mul}}"
                                               FontWeight="SemiBold" Foreground="#FF00FF88"/>
                                </StackPanel>
                                <!-- &#916;Brake -->
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="&#916;Fren" FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                               FontWeight="SemiBold" Opacity="0.75"
                                               Foreground="#FF8AABAB" Width="44" VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind ViewModel.LiveDeltaBrakeText, Mode=OneWay}"
                                               FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseMetric}, Converter={StaticResource Mul}}"
                                               FontWeight="SemiBold" Foreground="#FF00FF88"/>
                                </StackPanel>
                                <!-- &#916;Throttle -->
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="&#916;Acel" FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                               FontWeight="SemiBold" Opacity="0.75"
                                               Foreground="#FF8AABAB" Width="44" VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind ViewModel.LiveDeltaThrottleText, Mode=OneWay}"
                                               FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseMetric}, Converter={StaticResource Mul}}"
                                               FontWeight="SemiBold" Foreground="#FF00FF88"/>
                                </StackPanel>
                                <!-- &#916;YawGain -->
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="&#916;Yaw" FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                               FontWeight="SemiBold" Opacity="0.75"
                                               Foreground="#FF8AABAB" Width="44" VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind ViewModel.LiveDeltaYawGainText, Mode=OneWay}"
                                               FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseMetric}, Converter={StaticResource Mul}}"
                                               FontWeight="SemiBold" Foreground="#FF00FF88"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Proposals panel -->
                        <Border Grid.Column="3" Background="#FF0C1414"
                                BorderBrush="#FF2E4040" BorderThickness="1"
                                CornerRadius="{Binding Source={StaticResource CardCornerRadiusBase}, Converter={StaticResource ScaleCr}}"
                                Padding="{Binding Source={StaticResource CardPaddingBase}, Converter={StaticResource ScaleTh}}">
                            <StackPanel>

                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <TextBlock Text="&#128161;"
                                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="PROPUESTAS EN VIVO"
                                                   FontFamily="Consolas"
                                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                   FontWeight="SemiBold" Foreground="#FF00B4B4" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2">
                                        <ToggleButton Content="Single"
                                                      FontFamily="Consolas"
                                                      FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                      Padding="10,4"
                                                      IsChecked="{x:Bind ViewModel.IsSingleMode, Mode=TwoWay}"
                                                      Background="#FF0F2828" Foreground="#FFB0D0D0"
                                                      BorderBrush="#FF2E4040" CornerRadius="3,0,0,3"/>
                                        <ToggleButton Content="Multi-Optimize"
                                                      FontFamily="Consolas"
                                                      FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                      Padding="10,4"
                                                      IsChecked="{x:Bind ViewModel.IsMultiMode, Mode=TwoWay}"
                                                      Background="#FF0F2828" Foreground="#FFB0D0D0"
                                                      BorderBrush="#FF2E4040" CornerRadius="0,3,3,0"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Orientation="Horizontal" Spacing="2" Margin="0,0,0,6">
                                    <TextBlock Text="MODE" FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                               Foreground="#FF8AABAB" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ToggleButton Content="Sprint"
                                                  FontFamily="Consolas"
                                                  FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                  Padding="12,4"
                                                  IsChecked="{x:Bind ViewModel.IsSprintMode, Mode=TwoWay}"
                                                  Background="#FF0F2828" Foreground="#FFFFA040"
                                                  BorderBrush="#FF2E4040" CornerRadius="3,0,0,3"/>
                                    <ToggleButton Content="Endurance"
                                                  FontFamily="Consolas"
                                                  FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                  Padding="12,4"
                                                  IsChecked="{x:Bind ViewModel.IsEnduranceMode, Mode=TwoWay}"
                                                  Background="#FF0F2828" Foreground="#FF80E040"
                                                  BorderBrush="#FF2E4040" CornerRadius="0,3,3,0"/>
                                </StackPanel>

                                <!-- Single proposals -->
                                <ListView ItemsSource="{x:Bind ViewModel.Proposals}"
                                          SelectionMode="None" IsItemClickEnabled="False"
                                          MaxHeight="160"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          Visibility="{x:Bind ViewModel.IsSingleMode, Mode=OneWay}">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="MinHeight" Value="0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="models:Proposal">
                                            <Grid Padding="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="50"/>
                                                    <ColumnDefinition Width="44"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Background="#FF1A3030" CornerRadius="3"
                                                        Padding="4,2" Margin="0,1,4,1" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind Section}" FontFamily="Consolas"
                                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                               Foreground="#FF00D4B4" HorizontalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="{x:Bind Parameter}"
                                                           FontFamily="Consolas"
                                                           FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                           Foreground="#FFFFFFFF" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <Border Grid.Column="2" Background="#FF0F2010" CornerRadius="3"
                                                        Padding="4,2" Margin="0,1,4,1" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind Delta}" FontFamily="Consolas"
                                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                               Foreground="#FF00FF88" HorizontalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Grid.Column="3" Text="{x:Bind ConfidenceDisplay}"
                                                           FontFamily="Consolas"
                                                           FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                           Foreground="#FFFFA040"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBlock Grid.Column="4" Text="{x:Bind Reason}"
                                                           FontFamily="Consolas"
                                                           FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                           Foreground="#FF8AABAB" VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <!-- Multi-optimize combinations -->
                                <ListView ItemsSource="{x:Bind ViewModel.CombinedProposals}"
                                          SelectionMode="Single"
                                          SelectedItem="{x:Bind ViewModel.SelectedCombinedProposal, Mode=TwoWay}"
                                          MaxHeight="200"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          Visibility="{x:Bind ViewModel.IsMultiMode, Mode=OneWay}">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="MinHeight" Value="0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="telemetry:CombinedProposal">
                                            <Border Background="#FF0D1E1E" CornerRadius="5"
                                                    Padding="8,6" Margin="0,3">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0"
                                                               Text="{x:Bind ChangesDisplay}"
                                                               FontFamily="Consolas"
                                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                               Foreground="#FF00D4B4" TextWrapping="Wrap"/>
                                                    <StackPanel Grid.Row="1" Orientation="Horizontal"
                                                                Spacing="10" Margin="0,3,0,0">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <TextBlock Text="&#916;score"
                                                                       FontFamily="Consolas"
                                                                       FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                                       Opacity="0.75" Foreground="#FF8AABAB" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{x:Bind ScoreDeltaDisplay}"
                                                                       FontFamily="Consolas"
                                                                       FontSize="{Binding Source={StaticResource FontBaseNormal}, Converter={StaticResource Mul}}"
                                                                       FontWeight="Bold" Foreground="#FF00FF88" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{x:Bind RiskDisplay}"
                                                                   FontFamily="Consolas"
                                                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                                   Foreground="#FFFFA040" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <Button Grid.Row="2"
                                                            Content="&#9654; Test Combo"
                                                            FontFamily="Consolas"
                                                            FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                            Padding="10,4" Margin="0,4,0,0"
                                                            Background="#FF142828" Foreground="#FF00B4B4"
                                                            BorderBrush="#FF2E5050" CornerRadius="4"
                                                            Tag="{x:Bind}"
                                                            Click="OnTestComboClicked"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <TextBlock Text="No combinations yet &#8212; waiting for corner data&#8230;"
                                           FontFamily="Consolas"
                                           FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                           Opacity="0.5" Foreground="#FF8AABAB"
                                           HorizontalAlignment="Center" Margin="0,8,0,0"
                                           Visibility="{x:Bind ViewModel.IsMultiEmptyState, Mode=OneWay}"/>

                            </StackPanel>
                        </Border>

                    </Grid>
                </Border>
                </ScrollViewer>
            </TabViewItem>

            <!-- ── Setup Optimizer ────────────────── -->
            <TabViewItem Header="Setup Optimizer" IsClosable="False">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0"
                            Background="#FF0C1414" BorderBrush="#FF2E4040"
                            BorderThickness="1,1,1,0" CornerRadius="8,8,0,0" Padding="14,10">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="&#128295;"
                                       FontSize="{Binding Source={StaticResource FontBaseNormal}, Converter={StaticResource Mul}}"/>
                            <TextBlock Text="Pasos de Mejora del Setup"
                                       FontFamily="Consolas"
                                       FontSize="{Binding Source={StaticResource FontBaseNormal}, Converter={StaticResource Mul}}"
                                       FontWeight="SemiBold" Foreground="#FF00B4B4"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1"
                            Background="#FF060E0E" BorderBrush="#FF2E4040"
                            BorderThickness="1,0,1,1" CornerRadius="0,0,8,8">
                        <ScrollViewer x:Name="SetupScrollViewer"
                                      Padding="10" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{x:Bind ViewModel.SetupLogs}"
                                          ItemTemplate="{StaticResource AnalysisEntryRow}"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabViewItem>

            <!-- ── ML &amp; Policy ──── -->
            <TabViewItem Header="ML &amp; Policy" IsClosable="False">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                <Border Background="#FF0A1010"
                        BorderBrush="#FF2E4040" BorderThickness="0,0,0,1"
                        Padding="10,8">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Candidate cards -->
                        <StackPanel Grid.Column="0" Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                                <TextBlock Text="&#127919;"
                                           FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="CANDIDATOS PROBABIL&#205;STICOS"
                                           FontFamily="Consolas"
                                           FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                           FontWeight="SemiBold" Foreground="#FF00B4B4" VerticalAlignment="Center"/>
                                <TextBlock Text="Safe &#183; Balanced &#183; Aggressive"
                                           FontFamily="Consolas"
                                           FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                           Opacity="0.6" Foreground="#FF8AABAB" VerticalAlignment="Center"/>
                            </StackPanel>

                            <ItemsControl ItemsSource="{x:Bind ViewModel.AdvisedCandidates}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="8"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="ml:DecisionCandidate">
                                        <Border MinWidth="220" MaxWidth="300"
                                                CornerRadius="{Binding Source={StaticResource CardCornerRadiusBase}, Converter={StaticResource ScaleCr}}"
                                                Padding="{Binding Source={StaticResource CardPaddingBase}, Converter={StaticResource ScaleTh}}"
                                                BorderThickness="1">
                                            <Border.Background>
                                                <SolidColorBrush Color="#FF122020"/>
                                            </Border.Background>
                                            <Border.BorderBrush>
                                                <SolidColorBrush Color="#FF2A4040"/>
                                            </Border.BorderBrush>
                                            <StackPanel Spacing="6">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Border CornerRadius="4" Padding="6,3">
                                                        <Border.Background>
                                                            <SolidColorBrush Color="#FF142828"/>
                                                        </Border.Background>
                                                        <TextBlock Text="{x:Bind TierDisplay}"
                                                                   FontFamily="Consolas"
                                                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                                   FontWeight="SemiBold" Foreground="#FF00D4B4"/>
                                                    </Border>
                                                    <TextBlock Text="{x:Bind ProposalDisplay}"
                                                               FontFamily="Consolas"
                                                               FontSize="{Binding Source={StaticResource FontBaseNormal}, Converter={StaticResource Mul}}"
                                                               FontWeight="SemiBold" Foreground="#FFFFFFFF"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="14">
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="&#956;&#916;score"
                                                                   FontFamily="Consolas"
                                                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                                   FontWeight="SemiBold" Opacity="0.75" Foreground="#FF8AABAB"/>
                                                        <TextBlock Text="{x:Bind MeanDisplay}"
                                                                   FontFamily="Consolas"
                                                                   FontSize="{Binding Source={StaticResource FontBaseMetric}, Converter={StaticResource Mul}}"
                                                                   FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                                                    </StackPanel>
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="Risk"
                                                                   FontFamily="Consolas"
                                                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                                   FontWeight="SemiBold" Opacity="0.75" Foreground="#FF8AABAB"/>
                                                        <TextBlock Text="{x:Bind RiskDisplay}"
                                                                   FontFamily="Consolas"
                                                                   FontSize="{Binding Source={StaticResource FontBaseNormal}, Converter={StaticResource Mul}}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{x:Bind RiskForeground}"/>
                                                    </StackPanel>
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="Conf"
                                                                   FontFamily="Consolas"
                                                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                                   FontWeight="SemiBold" Opacity="0.75" Foreground="#FF8AABAB"/>
                                                        <TextBlock Text="{x:Bind ConfidenceDisplay}"
                                                                   FontFamily="Consolas"
                                                                   FontSize="{Binding Source={StaticResource FontBaseNormal}, Converter={StaticResource Mul}}"
                                                                   FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <StackPanel Spacing="3">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Text="80%"
                                                                   FontFamily="Consolas"
                                                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                                   Opacity="0.75" Foreground="#FF8AABAB" Width="28"/>
                                                        <TextBlock Text="{x:Bind Interval80Display}"
                                                                   FontFamily="Consolas"
                                                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                                   Foreground="#FFFFFFFF"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Text="95%"
                                                                   FontFamily="Consolas"
                                                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                                   Opacity="0.75" Foreground="#FF8AABAB" Width="28"/>
                                                        <TextBlock Text="{x:Bind Interval95Display}"
                                                                   FontFamily="Consolas"
                                                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                                   Foreground="#FFB0C8C8"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <TextBlock Text="{x:Bind Explanation}"
                                                           FontFamily="Consolas"
                                                           FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                           Opacity="0.65" Foreground="#FF8AABAB"
                                                           TextWrapping="Wrap" MaxLines="3"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Decision Inspector -->
                        <Border Grid.Column="1"
                                Background="#FF0A1018"
                                BorderBrush="#FF1E3040" BorderThickness="1"
                                CornerRadius="{Binding Source={StaticResource CardCornerRadiusBase}, Converter={StaticResource ScaleCr}}"
                                Padding="{Binding Source={StaticResource CardPaddingBase}, Converter={StaticResource ScaleTh}}">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="&#128269;"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="DECISION INSPECTOR"
                                               FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                               FontWeight="SemiBold" Foreground="#FF00B4B4" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Weights (AdaptiveWeightEngine)"
                                               FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                               Opacity="0.6" Foreground="#FF8AABAB"/>
                                    <TextBlock Text="{x:Bind ViewModel.WeightsDisplayText, Mode=OneWay}"
                                               FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseNormal}, Converter={StaticResource Mul}}"
                                               FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Driver vs Setup"
                                               FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                               Opacity="0.6" Foreground="#FF8AABAB"/>
                                    <TextBlock Text="{x:Bind ViewModel.DiscriminatorExplanationText, Mode=OneWay}"
                                               FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseNormal}, Converter={StaticResource Mul}}"
                                               Foreground="#FFFFA040"
                                               TextWrapping="Wrap" MaxLines="2"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Ranking Rationale"
                                               FontFamily="Consolas"
                                               FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                               Opacity="0.6" Foreground="#FF8AABAB"/>
                                    <ScrollViewer MaxHeight="120"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <TextBlock Text="{x:Bind ViewModel.DecisionInspectorText, Mode=OneWay}"
                                                   FontFamily="Consolas"
                                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                   Foreground="#FFB0C8C8" TextWrapping="Wrap"/>
                                    </ScrollViewer>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </Grid>
                </Border>
                </ScrollViewer>
            </TabViewItem>

            <!-- ── History ────────────────── -->
            <TabViewItem Header="History" IsClosable="False">
                <Grid ColumnSpacing="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="8,8,4,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Background="#FF0C1414" BorderBrush="#FF2E4040"
                                BorderThickness="1,1,1,0" CornerRadius="8,8,0,0" Padding="14,10">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="&#128663;"
                                           FontSize="{Binding Source={StaticResource FontBaseNormal}, Converter={StaticResource Mul}}"/>
                                <TextBlock Text="Comportamiento del Coche"
                                           FontFamily="Consolas"
                                           FontSize="{Binding Source={StaticResource FontBaseNormal}, Converter={StaticResource Mul}}"
                                           FontWeight="SemiBold" Foreground="#FF00B4B4"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1"
                                Background="#FF060E0E" BorderBrush="#FF2E4040"
                                BorderThickness="1,0,1,1" CornerRadius="0,0,8,8">
                            <ScrollViewer x:Name="BehaviorScrollViewer"
                                          Padding="10" VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{x:Bind ViewModel.BehaviorLogs}"
                                              ItemTemplate="{StaticResource AnalysisEntryRow}"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <Grid Grid.Column="1" Margin="4,8,8,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Background="#FF0C1414" BorderBrush="#FF2E4040"
                                BorderThickness="1,1,1,0" CornerRadius="8,8,0,0" Padding="14,10">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="&#9203;"
                                           FontSize="{Binding Source={StaticResource FontBaseNormal}, Converter={StaticResource Mul}}"/>
                                <TextBlock Text="An&#225;lisis de Tiempo de Conducci&#243;n"
                                           FontFamily="Consolas"
                                           FontSize="{Binding Source={StaticResource FontBaseNormal}, Converter={StaticResource Mul}}"
                                           FontWeight="SemiBold" Foreground="#FF00B4B4"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1"
                                Background="#FF060E0E" BorderBrush="#FF2E4040"
                                BorderThickness="1,0,1,1" CornerRadius="0,0,8,8">
                            <ScrollViewer x:Name="DrivingScrollViewer"
                                          Padding="10" VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{x:Bind ViewModel.DrivingLogs}"
                                              ItemTemplate="{StaticResource AnalysisEntryRow}"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>

                </Grid>
            </TabViewItem>

            <!-- ── Technical Inspector ──────────────── -->
            <TabViewItem Header="Technical Inspector" IsClosable="False">
                <Grid Margin="8,4,8,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0"
                            Background="#FF0C1414" BorderBrush="#FF2E4040"
                            BorderThickness="1,1,1,0" CornerRadius="8,8,0,0" Padding="14,10">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="&#127950;"
                                       FontSize="{Binding Source={StaticResource FontBaseNormal}, Converter={StaticResource Mul}}"/>
                            <TextBlock Text="Resumen de Fases de Curva"
                                       FontFamily="Consolas"
                                       FontSize="{Binding Source={StaticResource FontBaseNormal}, Converter={StaticResource Mul}}"
                                       FontWeight="SemiBold" Foreground="#FF00B4B4"/>
                            <TextBlock Text="segmentaci&#243;n por G lateral &#8212; an&#225;lisis por curva detectada"
                                       FontFamily="Consolas"
                                       FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                       Opacity="0.6" Foreground="#FF8AABAB" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1"
                            Background="#FF060E0E" BorderBrush="#FF2E4040"
                            BorderThickness="1,0,1,1" CornerRadius="0,0,8,8">
                        <ScrollViewer x:Name="CornerScrollViewer"
                                      Padding="10" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{x:Bind ViewModel.CornerLogs}"
                                          ItemTemplate="{StaticResource AnalysisEntryRow}"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabViewItem>

            <!-- ── Agent Logs Tab ─────────────────────────────────────────── -->
            <TabViewItem Header="Logs" IsClosable="False">
                <Grid Margin="8,4,8,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0"
                            Background="#FF0C1414" BorderBrush="#FF2E4040"
                            BorderThickness="1,1,1,0" CornerRadius="8,8,0,0" Padding="14,10">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="&#128220;"
                                       FontSize="{Binding Source={StaticResource FontBaseNormal}, Converter={StaticResource Mul}}"/>
                            <TextBlock Text="Agent Logs"
                                       FontFamily="Consolas"
                                       FontSize="{Binding Source={StaticResource FontBaseNormal}, Converter={StaticResource Mul}}"
                                       FontWeight="SemiBold" Foreground="#FF00B4B4"/>
                            <TextBlock Text="streaming en vivo &#8212; &#250;ltimas 500 l&#237;neas"
                                       FontFamily="Consolas"
                                       FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                       Opacity="0.6" Foreground="#FF8AABAB" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1"
                            Background="#FF060E0E" BorderBrush="#FF2E4040"
                            BorderThickness="1,0,1,1" CornerRadius="0,0,8,8">
                        <ScrollViewer x:Name="AgentLogsScrollViewer"
                                      Padding="10" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{x:Bind ViewModel.Logs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="agent:AgentLogEntry">
                                        <TextBlock FontFamily="Consolas"
                                                   FontSize="{Binding Source={StaticResource FontBaseSmall}, Converter={StaticResource Mul}}"
                                                   Foreground="#FFB0D0D0"
                                                   TextWrapping="Wrap"
                                                   Margin="0,1"
                                                   Text="{x:Bind DisplayText}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabViewItem>

        </TabView>

        <!-- ── HUD Quick Overlay: TAB → show, auto-hides after 2 s ──────────── -->
        <!-- Floats at top-center of the tab content area; ZIndex below Race View. -->
        <controls:HudOverlay x:Name="HudOverlay"
                             Grid.Row="2"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Top"
                             Margin="0,12,0,0"
                             Canvas.ZIndex="8"
                             Visibility="Collapsed"/>

        <!-- ── Race View overlay ──────────────────────────────────────────── -->
        <!-- Spans all rows; appears on top of everything when RaceViewMode.   -->
        <!-- Designed for 1920×1080 readability at 1–1.5 m from the screen.  -->
        <Grid x:Name="RaceViewOverlay"
              Grid.RowSpan="3"
              Background="#FF080E0E"
              Visibility="Collapsed"
              Canvas.ZIndex="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Row 0: Speed / Gear / RPM ─────────────────────────────── -->
            <Grid Grid.Row="0"
                  HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Speed -->
                <StackPanel Grid.Column="0" Spacing="6" HorizontalAlignment="Center">
                    <TextBlock Text="VEL"
                               FontFamily="Consolas"
                               FontSize="{Binding Source={StaticResource FontRaceLabel}, Converter={StaticResource Mul}}"
                               FontWeight="SemiBold" Foreground="#FF8AABAB"
                               HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.Channels[0].RealDisplay, Mode=OneWay}"
                                   FontFamily="Consolas"
                                   FontSize="{Binding Source={StaticResource FontRaceSpeed}, Converter={StaticResource Mul}}"
                                   FontWeight="Bold" Foreground="#FFFFFFFF"/>
                        <TextBlock Text="km/h"
                                   FontFamily="Consolas"
                                   FontSize="{Binding Source={StaticResource FontRaceLabel}, Converter={StaticResource Mul}}"
                                   Foreground="#FF8AABAB"
                                   VerticalAlignment="Bottom" Margin="0,0,0,12"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Width="1" Background="#33FFFFFF"
                        VerticalAlignment="Stretch" Margin="0,24"/>

                <!-- Gear -->
                <StackPanel Grid.Column="2" Spacing="6" HorizontalAlignment="Center" MinWidth="140">
                    <TextBlock Text="MARCHA"
                               FontFamily="Consolas"
                               FontSize="{Binding Source={StaticResource FontRaceLabel}, Converter={StaticResource Mul}}"
                               FontWeight="SemiBold" Foreground="#FF8AABAB"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{x:Bind ViewModel.Channels[2].RealDisplay, Mode=OneWay}"
                               FontFamily="Consolas"
                               FontSize="{Binding Source={StaticResource FontRaceGear}, Converter={StaticResource Mul}}"
                               FontWeight="Bold" Foreground="#FFFFFFFF"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <Border Grid.Column="3" Width="1" Background="#33FFFFFF"
                        VerticalAlignment="Stretch" Margin="0,24"/>

                <!-- RPM -->
                <StackPanel Grid.Column="4" Spacing="6" HorizontalAlignment="Center">
                    <TextBlock Text="RPM"
                               FontFamily="Consolas"
                               FontSize="{Binding Source={StaticResource FontRaceLabel}, Converter={StaticResource Mul}}"
                               FontWeight="SemiBold" Foreground="#FF8AABAB"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{x:Bind ViewModel.Channels[1].RealDisplay, Mode=OneWay}"
                               FontFamily="Consolas"
                               FontSize="{Binding Source={StaticResource FontRaceRpm}, Converter={StaticResource Mul}}"
                               FontWeight="Bold" Foreground="#FFFFFFFF"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Horizontal divider between rows -->
            <Border Grid.Row="1" Height="1" Background="#22FFFFFF"
                    VerticalAlignment="Top" Margin="40,0"/>

            <!-- ── Row 1: Delta / Throttle / Brake ───────────────────────── -->
            <Grid Grid.Row="1"
                  HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Delta vs Ideal -->
                <StackPanel Grid.Column="0" Spacing="6" HorizontalAlignment="Center" MinWidth="200">
                    <TextBlock Text="DELTA"
                               FontFamily="Consolas"
                               FontSize="{Binding Source={StaticResource FontRaceLabel}, Converter={StaticResource Mul}}"
                               FontWeight="SemiBold" Foreground="#FF8AABAB"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{x:Bind ViewModel.LapDelta, Mode=OneWay}"
                               FontFamily="Consolas"
                               FontSize="{Binding Source={StaticResource FontRaceDelta}, Converter={StaticResource Mul}}"
                               FontWeight="Bold" Foreground="#FF00FF88"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <Border Grid.Column="1" Width="1" Background="#33FFFFFF"
                        VerticalAlignment="Stretch" Margin="0,24"/>

                <!-- Throttle -->
                <StackPanel Grid.Column="2" Spacing="6" HorizontalAlignment="Center" MinWidth="200">
                    <TextBlock Text="ACELERADOR"
                               FontFamily="Consolas"
                               FontSize="{Binding Source={StaticResource FontRaceLabel}, Converter={StaticResource Mul}}"
                               FontWeight="SemiBold" Foreground="#FF8AABAB"
                               HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.Channels[3].RealDisplay, Mode=OneWay}"
                                   FontFamily="Consolas"
                                   FontSize="{Binding Source={StaticResource FontRaceInput}, Converter={StaticResource Mul}}"
                                   FontWeight="Bold" Foreground="#FF00FF88"/>
                        <TextBlock Text="%"
                                   FontFamily="Consolas"
                                   FontSize="{Binding Source={StaticResource FontRaceLabel}, Converter={StaticResource Mul}}"
                                   Foreground="#FF8AABAB"
                                   VerticalAlignment="Bottom" Margin="0,0,0,8"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="3" Width="1" Background="#33FFFFFF"
                        VerticalAlignment="Stretch" Margin="0,24"/>

                <!-- Brake -->
                <StackPanel Grid.Column="4" Spacing="6" HorizontalAlignment="Center" MinWidth="200">
                    <TextBlock Text="FRENO"
                               FontFamily="Consolas"
                               FontSize="{Binding Source={StaticResource FontRaceLabel}, Converter={StaticResource Mul}}"
                               FontWeight="SemiBold" Foreground="#FF8AABAB"
                               HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.Channels[4].RealDisplay, Mode=OneWay}"
                                   FontFamily="Consolas"
                                   FontSize="{Binding Source={StaticResource FontRaceInput}, Converter={StaticResource Mul}}"
                                   FontWeight="Bold" Foreground="#FFFF5050"/>
                        <TextBlock Text="%"
                                   FontFamily="Consolas"
                                   FontSize="{Binding Source={StaticResource FontRaceLabel}, Converter={StaticResource Mul}}"
                                   Foreground="#FF8AABAB"
                                   VerticalAlignment="Bottom" Margin="0,0,0,8"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- ── Row 2: Phase + Lap time footer ────────────────────────── -->
            <Border Grid.Row="2"
                    BorderBrush="#22FFFFFF" BorderThickness="0,1,0,0"
                    Padding="24,16">
                <StackPanel Orientation="Horizontal" Spacing="48"
                            HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="FASE"
                                   FontFamily="Consolas"
                                   FontSize="{Binding Source={StaticResource FontRaceLabel}, Converter={StaticResource Mul}}"
                                   Foreground="#FF8AABAB" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Bind ViewModel.CurrentPhase, Mode=OneWay}"
                                   FontFamily="Consolas"
                                   FontSize="{Binding Source={StaticResource FontBaseMetric}, Converter={StaticResource Mul}}"
                                   FontWeight="SemiBold" Foreground="#FFFFFFFF"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="VUELTA"
                                   FontFamily="Consolas"
                                   FontSize="{Binding Source={StaticResource FontRaceLabel}, Converter={StaticResource Mul}}"
                                   Foreground="#FF8AABAB" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Bind ViewModel.LapTimeReal, Mode=OneWay}"
                                   FontFamily="Consolas"
                                   FontSize="{Binding Source={StaticResource FontBaseMetric}, Converter={StaticResource Mul}}"
                                   FontWeight="SemiBold" Foreground="#FFFFFFFF"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="IDEAL"
                                   FontFamily="Consolas"
                                   FontSize="{Binding Source={StaticResource FontRaceLabel}, Converter={StaticResource Mul}}"
                                   Foreground="#FF8AABAB" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Bind ViewModel.LapTimeIdeal, Mode=OneWay}"
                                   FontFamily="Consolas"
                                   FontSize="{Binding Source={StaticResource FontBaseMetric}, Converter={StaticResource Mul}}"
                                   FontWeight="SemiBold" Foreground="#FFFFFFFF"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </Grid>

    </Grid>

</Page>
