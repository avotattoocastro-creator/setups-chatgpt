<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="AvoPerformanceSetupAI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AvoPerformanceSetupAI"
    xmlns:views="using:AvoPerformanceSetupAI.Views"
    xmlns:controls="using:AvoPerformanceSetupAI.Controls"
    Title="AvoPerformanceSetupAI">

    <Grid Background="{StaticResource CarbonBackgroundBrush}" Loaded="RootGrid_Loaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Watermark: rendered first (behind everything), spans entire window -->
        <Image x:Name="WatermarkImage"
               Grid.RowSpan="2"
               Source="ms-appx:///Assets/Brand/avo_performance.png"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               IsHitTestVisible="False"
               AutomationProperties.Name="AVO Performance watermark"/>

        <!-- Custom Title Bar -->
        <Grid Grid.Row="0" Background="#FF0A1414" x:Name="TitleBarGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                <Image Source="ms-appx:///Assets/Brand/avo_performance.png"
                       Height="30" Stretch="Uniform"
                       VerticalAlignment="Center" Margin="0,0,8,0"
                       IsHitTestVisible="False" Opacity="0.90"
                       AutomationProperties.Name="AVO Performance logo"/>
                <TextBlock Text="AvoPerformanceSetupAI" FontSize="13" FontWeight="SemiBold"
                           Foreground="#FFE0F0F0" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Main Tab View -->
        <TabView Grid.Row="1" x:Name="MainTabView"
                 Background="Transparent"
                 TabWidthMode="Equal"
                 IsAddTabButtonVisible="False"
                 SelectionChanged="MainTabView_SelectionChanged">
            <TabView.Resources>
                <SolidColorBrush x:Key="TabViewBackground" Color="Transparent" />
            </TabView.Resources>

            <TabViewItem x:Name="TabConfiguracion" Header="Configuración" IsClosable="False">
                <views:ConfiguracionPage />
            </TabViewItem>

            <TabViewItem x:Name="TabSesiones" Header="Sesiones" IsClosable="False">
                <views:SesionesPage />
            </TabViewItem>

            <TabViewItem x:Name="TabTelemetria" Header="📡 Telemetría" IsClosable="False">
                <views:TelemetryPage />
            </TabViewItem>

            <TabViewItem x:Name="TabTerminal" Header="🖥 Terminal" IsClosable="False">
                <views:TerminalPage />
            </TabViewItem>

            <TabViewItem x:Name="TabSetupDiff" Header="🔀 Setup Diff" IsClosable="False">
                <views:SetupDiffPage />
            </TabViewItem>

            <TabViewItem x:Name="TabIa" Header="🤖 IA" IsClosable="False">
                <views:IaPage />
            </TabViewItem>
        </TabView>

        <!-- Startup splash overlay: last child so it renders above everything -->
        <controls:StartupSplashOverlay x:Name="SplashOverlay"
                                       Grid.RowSpan="2"
                                       Canvas.ZIndex="100"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"/>
    </Grid>
</Window>
