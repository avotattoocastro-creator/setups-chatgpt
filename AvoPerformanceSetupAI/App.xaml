<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="AvoPerformanceSetupAI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:AvoPerformanceSetupAI.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ── UI scale (1.0 = 100 %; updated at runtime when user changes slider) ── -->
            <x:Double x:Key="UiScale">1.0</x:Double>

            <!-- ── Font size base values (multiplied by UiScale via MultiplyConverter) ── -->
            <x:Double x:Key="FontBaseSmall">14</x:Double>
            <x:Double x:Key="FontBaseNormal">16</x:Double>
            <x:Double x:Key="FontBaseMetric">22</x:Double>
            <x:Double x:Key="FontBaseBigMetric">28</x:Double>
            <x:Double x:Key="FontBaseScore">42</x:Double>

            <!-- ── Race View font sizes (larger, for 1–1.5 m reading distance) ── -->
            <x:Double x:Key="FontRaceSpeed">64</x:Double>
            <x:Double x:Key="FontRaceGear">54</x:Double>
            <x:Double x:Key="FontRaceRpm">40</x:Double>
            <x:Double x:Key="FontRaceDelta">38</x:Double>
            <x:Double x:Key="FontRaceInput">34</x:Double>
            <x:Double x:Key="FontRaceLabel">18</x:Double>

            <!-- ── Card sizing base values ── -->
            <x:Double x:Key="CardCornerRadiusBase">10</x:Double>
            <x:Double x:Key="CardPaddingBase">16</x:Double>
            <x:Double x:Key="CardMarginBase">12</x:Double>
            <x:Double x:Key="CardMinHeightBase">90</x:Double>

            <!-- ── Scaling converters ── -->
            <converters:MultiplyConverter        x:Key="Mul"/>
            <converters:ScaleThicknessConverter  x:Key="ScaleTh"/>
            <converters:ScaleCornerRadiusConverter x:Key="ScaleCr"/>
            <converters:BoolToYesNoConverter     x:Key="BoolToYesNoConverter"/>
            <converters:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>

            <!-- Card background -->
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FF1E2A2A" />
            <SolidColorBrush x:Key="CardBorderBrush" Color="#FF2E4040" />
            <SolidColorBrush x:Key="TealBrush" Color="#FF00B4B4" />
            <SolidColorBrush x:Key="TealDarkBrush" Color="#FF007A7A" />

            <!-- Run button style -->
            <Style x:Key="RunButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="#FF00B4B4" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Height" Value="56" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
            </Style>

            <!-- Accent button style -->
            <Style x:Key="AccentActionButton" TargetType="Button">
                <Setter Property="Background" Value="#FF00B4B4" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Padding" Value="12,6" />
            </Style>

            <!-- Secondary button style -->
            <Style x:Key="SecondaryActionButton" TargetType="Button">
                <Setter Property="Background" Value="#FF2A3A3A" />
                <Setter Property="Foreground" Value="#FFB0C8C8" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Padding" Value="12,6" />
            </Style>

            <!-- Filter pill button style -->
            <Style x:Key="FilterPillStyle" TargetType="Button">
                <Setter Property="Background" Value="#FF1E2A2A" />
                <Setter Property="Foreground" Value="#FF8AABAB" />
                <Setter Property="BorderBrush" Value="#FF2E4040" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="10,3" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontFamily" Value="Consolas" />
            </Style>

            <!-- Carbon background: subtle diagonal gradient simulating a dark carbon-fibre texture -->
            <LinearGradientBrush x:Key="CarbonBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF0C1818" Offset="0.00"/>
                <GradientStop Color="#FF122020" Offset="0.25"/>
                <GradientStop Color="#FF0A1616" Offset="0.50"/>
                <GradientStop Color="#FF131F1F" Offset="0.75"/>
                <GradientStop Color="#FF0E1C1C" Offset="1.00"/>
            </LinearGradientBrush>

            <!-- Convenience style: apply CarbonBackgroundBrush as a Grid background -->
            <Style x:Key="CarbonBackground" TargetType="Grid">
                <Setter Property="Background" Value="{StaticResource CarbonBackgroundBrush}"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
